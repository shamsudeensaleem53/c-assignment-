// Question 1: Take two integers and calculate sum, difference, product, and quotient
#include <iostream>
using namespace std;

int main() {
    int a, b;
    cout << "Enter first integer: ";
    cin >> a;
    cout << "Enter second integer: ";
    cin >> b;

    int sum = a + b;
    int difference = a - b;
    int product = a * b;
    // Cast to double so the quotient isn't truncated by integer division
    double quotient = static_cast<double>(a) / b;

    cout << "Sum: " << sum << endl;
    cout << "Difference: " << difference << endl;
    cout << "Product: " << product << endl;
    cout << "Quotient: " << quotient << endl;

    return 0;
}
